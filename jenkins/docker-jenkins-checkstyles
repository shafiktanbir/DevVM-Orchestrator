pipeline {
    agent {
        docker {
            image 'maven:3.9.9-eclipse-temurin-17'
            args '-v $HOME/.m2:/root/.m2'
        }
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'atom',
                    url: 'https://github.com/hkhcoder/vprofile-project.git',
                    credentialsId: null // No credentials specified
            }
        }

        stage('Unit Test') {
            steps {
                sh 'mvn test'
                // Checkstyle runs automatically via maven-checkstyle-plugin in pom.xml
                junit testResults: '**/target/surefire-reports/*.xml', allowEmptyResults: true
                archiveArtifacts artifacts: '**/target/surefire-reports/*.xml', allowEmptyArchive: true
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean package -DskipTests'
            }
        }

        stage('Archive WAR') {
            steps {
                // **/ covers WAR in a Maven submodule (e.g. vprofile)
                archiveArtifacts artifacts: '**/target/*.war', fingerprint: true, allowEmptyArchive: false
            }
        }
    }

    post {
        always {
            cleanWs()
        }
        failure {
            echo 'Pipeline failed. Check console output for details.'
        }
    }
}
